{
    "name": "pr-run",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "dist-electron/main.js",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "backend": "bun src/backend/server.ts",
        "backend:dev": "PR_RUN_BACKEND_PORT=3001 bun --watch src/backend/server.ts",
        "renderer:dev": "bunx vite dev --host localhost",
        "dev": "sh -c 'trap \"kill 0\" EXIT; bun run backend:dev & bun run renderer:dev'",
        "build": "bun run build:renderer && bun run build:electron",
        "build:electron": "tsc -p tsconfig.electron.json && cp electron/package.json dist-electron/package.json",
        "build:renderer": "tsc -b tsconfig.app.json && vite build",
        "electron": "bun run build && electron .",
        "electron:dev": "sh -c 'trap \"kill 0\" EXIT; bun run backend:dev & bun run renderer:dev & bun run build:electron && ELECTRON_BACKEND_URL=http://localhost:3001 ELECTRON_RENDERER_URL=http://localhost:5173 ELECTRON_SKIP_BACKEND_HEALTHCHECK=1 electron .'",
        "preview": "vite preview"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.2",
        "@fontsource-variable/dm-sans": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@heroicons/react": "^2.2.0",
        "@heroui/react": "^3.1.0",
        "@heroui/styles": "^3.1.0",
        "@pierre/diffs": "^1.2.10",
        "@tanstack/react-query": "^5.101.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "effect": "^3.21.3",
        "elysia": "^1.4.28",
        "ky": "^2.0.2",
        "lucide-react": "^1.18.0",
        "node-pty": "^1.1.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "electron": "^42.4.0",
        "node-gyp": "^13.0.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    }
}
