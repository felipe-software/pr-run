{
    "name": "pr-run",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "dist-electron/main.js",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "backend": "bun src/backend/server.ts",
        "dev": "vite",
        "build": "bun run build:renderer && bun run build:electron",
        "build:electron": "tsc -p tsconfig.electron.json",
        "build:renderer": "tsc -b tsconfig.app.json && vite build",
        "electron": "bun run build && electron .",
        "electron:dev": "bun run build:electron && ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
        "preview": "vite preview"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.2",
        "@heroicons/react": "^2.2.0",
        "@heroui/react": "^3.1.0",
        "@heroui/styles": "^3.1.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "effect": "^3.21.3",
        "elysia": "^1.4.28",
        "lucide-react": "^1.18.0",
        "node-pty": "^1.1.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "electron": "^42.4.0",
        "node-gyp": "^13.0.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    }
}
