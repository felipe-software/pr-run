{
  "name": "pr-run",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:renderer && bun run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc -b tsconfig.app.json && vite build",
    "electron": "bun run build && electron .",
    "electron:dev": "bun run build:electron && ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
